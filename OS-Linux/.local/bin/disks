#!/bin/bash

# 🅲 🅷 🅰 🅽 🅳 🅴 🆁
# ---------------------------------------
# Prints information about attached disks

get_block_devices() {
    lsblk -de 7 -P -o NAME,MODEL,SIZE | awk '
    {
        name=model=size=rota="";
        for(i=1;i<=NF;i++) {
            if($i~/^NAME=/) {
                name=$i;
                sub(/^NAME="/,"",name);
                sub(/"$/,"",name)
            }

            else if($i~/^SIZE=/) {
                size=$i;
                sub(/^SIZE="/,"",size);
                sub(/"$/,"",size)

            } else if($i~/^MODEL=/) {
                model=substr($0,index($0,"MODEL=\"")+7);
                sub(/" SIZE=.*/,"",model)
            }
        }

        printf "%s||%s||%s\n",name,model,size
    }'
}

devices=$(get_block_devices)
printf "\033[1;33mNAME||SIZE||MODEL\033[0m\n%s\n" "$devices" | column -t -s '||'
